          <span class="brand-word__short" aria-hidden="true">atomistic</span>
        </span>
      </a>
      <div class="nav__links" id="nav-links">
        <a href="/mlx-atomistic/overview/">Overview</a>
        <a href="/mlx-atomistic/dft/dft-scf-core/">DFT</a>
