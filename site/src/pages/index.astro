              <radialGradient id="halo" cx="0.5" cy="0.5" r="0.5">
                <stop class="halo-stop" stop-opacity="0.85" />
                <stop offset="1" class="halo-stop" stop-opacity="0" />
              </radialGradient>
            </defs>
            <!-- board traces: the die's I/O (see TRACES/PACKETS) -->
            <g class="traces traces--wide">
              {TRACES.map((t) => (
                <path class="trace" d={t.d} />
              ))}
              {TRACES.map((t) => (
                <circle cx={t.via[0]} cy={t.via[1]} r="3" />
              ))}
              {PACKETS.map((p) => (
                <path class="packet" d={p.d} pathLength="100" style={`animation-delay:${p.delay}s`} />
              ))}
            </g>
            <g class="traces traces--narrow">
              {TRACES_N.map((t) => (
                <path class="trace" d={t.d} />
              ))}
              {TRACES_N.map((t) => (
                <circle cx={t.via[0]} cy={t.via[1]} r="3" />
              ))}
              {PACKETS_N.map((p) => (
                <path class="packet" d={p.d} pathLength="100" style={`animation-delay:${p.delay}s`} />
              ))}
            </g>
            <!-- package pins: pad-tipped, three per side (see PINS) -->
            <g class="pins">
              {PINS.map((p) => (
                <>
                  <line x1={p} y1="40" x2={p} y2="22" /><circle cx={p} cy="18" r="3.5" />
                  <line x1={p} y1="280" x2={p} y2="298" /><circle cx={p} cy="302" r="3.5" />
                  <line x1="40" y1={p} x2="22" y2={p} /><circle cx="18" cy={p} r="3.5" />
                  <line x1="280" y1={p} x2="298" y2={p} /><circle cx="302" cy={p} r="3.5" />
                </>
              ))}
            </g>
            <!-- silicon die: superellipse corners, concentric nesting -->
            <path d={DIE_PATH} fill="url(#die)" />
            <path d={DIE_PATH} class="die-edge" />
            <path d={INNER_PATH} class="die-inner" />
            <!-- Bonded crystallite, generated from SITES/EDGES (see
                 frontmatter). Every edge of the site graph gets a line; an
                 edge only shows while both of its sites are occupied, so the
                 network re-knits itself as the vacancy migrates. Halos carry
                 the per-atom thermal glow; the .exc overlays carry the
                 wandering exciton. The MD script animates every layer. -->
            <g class="bonds" data-sites={JSON.stringify(SITES.map((s) => [s.x, s.y]))}>
              {EDGES.map(([i, j]) => (
                <line
                  data-e={`${i} ${j}`}
                  x1={SITES[i].x}
                  y1={SITES[i].y}
                  x2={SITES[j].x}
                  y2={SITES[j].y}
                  style={i === VAC0 || j === VAC0 ? "stroke-opacity:0" : undefined}
                />
              ))}
            </g>
            <g class="halos">
              {ATOMS0.map((a) => (
                <circle cx={a.x} cy={a.y} r={a.r + 6} fill="url(#halo)" opacity="0" />
              ))}
            </g>
            <g class="atoms">
              {ATOMS0.map((a) => (
                <circle data-s={a.site} cx={a.x} cy={a.y} r={a.r} fill="url(#atom)" />
              ))}
            </g>
            <g class="excs">
              {ATOMS0.map((a) => (
                <circle
                  class="exc"
                  cx={a.x}
                  cy={a.y}
                  r={a.r}
                  fill="url(#atomA)"
                  style={`opacity:${EXC0.includes(a.site) ? 1 : 0}`}
                />
              ))}
            </g>
          </svg>
        </div>

        <!-- Live MD readout: phase (Lindemann criterion) + temperature. -->
        <div class="hero__readout" hidden>
          <span class="phase" data-phase="crystalline">Crystalline</span>
          <span class="thermo" aria-hidden="true"><i class="thermo__fill" data-temp></i></span>
        </div>
        <p class="hero__hint" hidden>
          Drag to heat the lattice past melting, then let go and watch it
          anneal back into a crystal.
        </p>
        </div>
      </section>

      <!-- Bento -->
      <section class="section">
        <p class="kicker">Capabilities</p>
        <h2 class="section-title">One runtime, two scales.</h2>
        <div class="bento">
          {
            features.map((f) => (
              <article class={`card card--${f.span}`}>
