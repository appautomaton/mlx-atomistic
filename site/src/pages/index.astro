        </a>
        <button id="nav-menu-btn" class="icon-btn nav__menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
          <svg class="icon-menu" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          <svg class="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
    </nav>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero__inner">
          <span class="eyebrow">Apple Silicon · MLX · Metal</span>
          <h1>
            Atomistic simulation,<br />
            <span class="accent">native to your Mac.</span>
          </h1>
          <p class="lead">
            An alpha MD and DFT runtime built directly on MLX and Metal — it runs the
            GPU on your machine, not a wrapper around someone else's cluster.
          </p>
          <div class="cta-row">
            <a class="btn btn--primary" href="/mlx-atomistic/overview/">Get started</a>
            <a class="btn btn--link" href="https://github.com/appautomaton/mlx-atomistic">
              View on GitHub
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>

        <div class="hero__stage">
        <!-- Hero visual: an orbital atom seated inside a silicon die. -->
        <div class="hero__visual" aria-hidden="true">
          <div class="hero__aurora"></div>
          <svg class="lattice" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="die" x1="40" y1="40" x2="280" y2="280" gradientUnits="userSpaceOnUse">
                <stop class="die-a" />
                <stop offset="1" class="die-b" />
              </linearGradient>
              <radialGradient id="atom" cx="0.35" cy="0.3" r="0.8">
                <stop class="atom-a" />
                <stop offset="1" class="atom-b" />
              </radialGradient>
              <radialGradient id="atomA" cx="0.35" cy="0.3" r="0.85">
                <stop class="atomA-a" />
                <stop offset="1" class="atomA-b" />
              </radialGradient>
            </defs>
            <!-- package pins -->
            <g class="pins">
              <!-- Irregular package pins — varied count, spacing and length. -->
              <line x1="118" y1="40" x2="118" y2="16" /><line x1="182" y1="40" x2="182" y2="22" />
              <line x1="104" y1="280" x2="104" y2="308" /><line x1="150" y1="280" x2="150" y2="298" /><line x1="214" y1="280" x2="214" y2="304" />
              <line x1="40" y1="128" x2="14" y2="128" /><line x1="40" y1="200" x2="20" y2="200" />
              <line x1="280" y1="112" x2="302" y2="112" /><line x1="280" y1="164" x2="308" y2="164" /><line x1="280" y1="220" x2="304" y2="220" />
            </g>
            <!-- silicon die -->
            <rect x="40" y="40" width="240" height="240" rx="40" fill="url(#die)" />
            <rect x="40" y="40" width="240" height="240" rx="40" class="die-edge" />
            <rect x="74" y="74" width="172" height="172" rx="26" class="die-inner" />
            <!-- close-packed atomic lattice (19-atom hex cluster) -->
            <!-- Lattice sites double as MD "home" positions; a script upgrades
                 this static lattice into an interactive molecular-dynamics toy. -->
            <g class="atoms">
              <!-- Asymmetric crystallite: the close-packed patch is rotated ~9deg
                   off-axis and nudged off-centre, with a trimmed left edge and one
                   interior vacancy (a point defect). The excited (teal) atoms form
                   an off-centre lobe rather than a symmetric ring. Each atom still
                   springs to its own home site, so the MD toy is unchanged. -->
              <circle cx="227.2" cy="173.6" r="8" fill="url(#atom)" />
              <circle cx="202.8" cy="110" r="8" fill="url(#atomA)" />
              <circle cx="135.6" cy="99.4" r="8" fill="url(#atom)" />
              <circle cx="117.2" cy="216" r="8" fill="url(#atom)" />
              <circle cx="184.4" cy="226.6" r="8" fill="url(#atom)" />
              <circle cx="214.9" cy="142.3" r="8" fill="url(#atomA)" />
              <circle cx="169.2" cy="104.7" r="8" fill="url(#atom)" />
              <circle cx="114.2" cy="126.4" r="8" fill="url(#atom)" />
              <circle cx="105.1" cy="183.7" r="8" fill="url(#atom)" />
              <circle cx="150.8" cy="221.3" r="8" fill="url(#atom)" />
              <circle cx="205.8" cy="199.6" r="8" fill="url(#atom)" />
              <circle cx="193.6" cy="168.3" r="9" fill="url(#atomA)" />
              <circle cx="181.3" cy="137" r="9" fill="url(#atomA)" />
              <circle cx="147.7" cy="131.7" r="9" fill="url(#atom)" />
              <circle cx="126.4" cy="157.7" r="9" fill="url(#atom)" />
              <circle cx="172.3" cy="194.3" r="9" fill="url(#atom)" />
              <circle cx="160" cy="163" r="10.5" fill="url(#atom)" />
            </g>
          </svg>
        </div>

        <!-- Live MD readout: phase (Lindemann criterion) + temperature. -->
        <div class="hero__readout" hidden>
          <span class="phase" data-phase="crystalline">Crystalline</span>
          <span class="thermo" aria-hidden="true"><i class="thermo__fill" data-temp></i></span>
        </div>
        <p class="hero__hint" hidden>
          Drag the lattice to add kinetic energy — heat it past melting, then
          let go and watch it re-crystallize.
        </p>
        </div>
      </section>

      <!-- Bento -->
      <section class="section">
        <p class="kicker">Capabilities</p>
        <h2 class="section-title">One runtime, two scales.</h2>
        <div class="bento">
          {
            features.map((f) => (
              <article class={`card card--${f.span}`}>
                <div class={`card__bg card__bg--${f.mask}`} set:html={cardViz(f.viz)} />
                <span class="card__icon" set:html={icon(f.icon)} />
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Stats -->
      <section class="stats">
        {
          stats.map((s) => (
            <div class="stat">
              <div class="stat__value">{s.value}</div>
              <div class="stat__label">{s.label}</div>
            </div>
          ))
        }
      </section>

      <!-- Quick start -->
      <section class="section section--narrow">
        <p class="kicker">Quick start</p>
        <h2 class="section-title">Try the alpha, then open a checkout.</h2>
        <div class="window">
          <div class="window__bar">
            <span class="traffic"><i class="t-red" /><i class="t-amber" /><i class="t-green" /></span>
            <span class="window__title">zsh — mlx-atomistic</span>
          </div>
          <pre><code><span class="c-comment"># try the PyPI alpha</span>
<span class="c-prompt">$</span> uv run --no-project --python 3.13 --with mlx-atomistic \
    python -c "import mlx_atomistic as ma; print(ma.__version__)"

<span class="c-comment"># work from a checkout</span>
<span class="c-prompt">$</span> uv venv --python 3.13
<span class="c-prompt">$</span> uv sync --extra notebook --extra prep --extra viz
<span class="c-prompt">$</span> uv run jupyter lab

<span class="c-comment"># run a DFT SCF benchmark</span>
<span class="c-prompt">$</span> uv run python -m mlx_atomistic.benchmarks.dft_scf \
    --sizes 8,16,24,32 --iterations 5 --mixer both --json</code></pre>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <span>
          mlx-atomistic · part of
          <a href="https://appautomaton.github.io" rel="me">App&nbsp;Automaton</a>
        </span>
        <div class="footer__links">
          <a href="/mlx-atomistic/overview/">Docs</a>
          <a href="https://github.com/appautomaton/mlx-atomistic">GitHub</a>
          <a href="https://appautomaton.github.io">App Automaton</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById("theme-toggle");
      toggle?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme || "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("starlight-theme", next);
      });

      // Condense the floating nav once the page scrolls past the top. A 1px
      // sentinel is cheaper and smoother than a scroll handler: the observer
      // fires only as it crosses the viewport edge.
      const nav = document.querySelector(".nav");
      const sentinel = document.getElementById("nav-sentinel");
      if (nav && sentinel && "IntersectionObserver" in window) {
        new IntersectionObserver(
          ([entry]) => nav.classList.toggle("is-scrolled", !entry.isIntersecting),
        ).observe(sentinel);
      }

      // Mobile menu: the hamburger toggles a dropdown of the nav links.
      // Closes on link tap, Escape, or a click outside the nav.
      const menuBtn = document.getElementById("nav-menu-btn");
      const setMenu = (open) => {
        nav?.setAttribute("data-menu", open ? "open" : "closed");
        menuBtn?.setAttribute("aria-expanded", String(open));
        menuBtn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      };
      menuBtn?.addEventListener("click", () =>
        setMenu(nav?.getAttribute("data-menu") !== "open"),
      );
      nav?.querySelectorAll(".nav__links a").forEach((a) =>
        a.addEventListener("click", () => setMenu(false)),
      );
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setMenu(false);
      });
      document.addEventListener("click", (e) => {
        if (nav?.getAttribute("data-menu") === "open" && !nav.contains(e.target))
          setMenu(false);
      });
    </script>

    <!-- Interactive molecular-dynamics toy on the hero lattice.
         Harmonic pull to each lattice site (Einstein crystal) + soft pairwise
         repulsion (excluded volume) + Langevin-style damping & thermal noise.
         Dragging injects kinetic energy (heat); the phase chip uses the
         Lindemann criterion (RMS displacement / nearest-neighbour spacing). -->
    <script>
      const visual = document.querySelector(".hero__visual");
      const svg = visual?.querySelector("svg.lattice");
      const group = svg?.querySelector(".atoms");
      const hero = visual?.closest(".hero");
      const phaseEl = hero?.querySelector("[data-phase]");
      const tempEl = hero?.querySelector("[data-temp]");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (visual && svg && group && !reduce) {
        hero?.querySelector(".hero__readout")?.removeAttribute("hidden");
        hero?.querySelector(".hero__hint")?.removeAttribute("hidden");

        const atoms = [...group.querySelectorAll("circle")].map((el) => {
          const hx = parseFloat(el.getAttribute("cx"));
          const hy = parseFloat(el.getAttribute("cy"));
          return { el, hx, hy, x: hx, y: hy, vx: 0, vy: 0 };
        });

        const SPRING = 0.022;   // harmonic pull to lattice site
        const DAMP = 0.88;      // cooling per frame (settle / recrystallize)
        const DAMP_HOT = 0.985; // barely cools while you stir
        const MOUSE_R = 72;     // cursor influence radius (viewBox units)
        const MOUSE_F = 1.5;    // cursor push strength
        const PAIR_R = 24;      // soft repulsion cutoff
        const PAIR_F = 0.45;
        const NOISE = 0.06;     // idle thermal vibration
        const MAXV = 14;        // velocity clamp (stability)
        const LO = 86, HI = 234; // simulation-cell walls
        const A_NN = 34;        // nearest-neighbour spacing
        const MELT = 0.16;      // Lindemann ratio at melting

        const mouse = { x: -999, y: -999, on: false, down: false };
        let heat = 0, frame = 0;

        const toSvg = (cx, cy) => {
          const r = svg.getBoundingClientRect();
          return { x: ((cx - r.left) / r.width) * 320, y: ((cy - r.top) / r.height) * 320 };
        };
        visual.addEventListener("pointermove", (e) => {
          const p = toSvg(e.clientX, e.clientY);
          mouse.x = p.x; mouse.y = p.y; mouse.on = true;
          if (mouse.down) heat = Math.min(heat + 0.5, 6);
        });
        visual.addEventListener("pointerdown", () => { mouse.down = true; });
        window.addEventListener("pointerup", () => { mouse.down = false; });
        visual.addEventListener("pointerleave", () => { mouse.on = false; });

        let raf = 0, running = false, inView = false;
        const tick = () => {
          heat *= 0.95;
          const damp = mouse.down ? DAMP_HOT : DAMP;
          const springK = SPRING * (1 - Math.min(heat / 6, 0.82));
          const temp = NOISE + heat;
          let ke = 0, msd = 0;

          for (const a of atoms) {
            a.vx += (a.hx - a.x) * springK;
            a.vy += (a.hy - a.y) * springK;
            if (mouse.on) {
              const dx = a.x - mouse.x, dy = a.y - mouse.y;
              const d = Math.hypot(dx, dy);
              if (d < MOUSE_R && d > 0.001) {
                const push = (1 - d / MOUSE_R) * MOUSE_F;
                a.vx += (dx / d) * push;
                a.vy += (dy / d) * push;
              }
            }
            a.vx += (Math.random() - 0.5) * temp;
            a.vy += (Math.random() - 0.5) * temp;
          }
          for (let i = 0; i < atoms.length; i++) {
            for (let j = i + 1; j < atoms.length; j++) {
              const a = atoms[i], b = atoms[j];
              const dx = b.x - a.x, dy = b.y - a.y;
              const d = Math.hypot(dx, dy);
              if (d < PAIR_R && d > 0.001) {
                const push = (1 - d / PAIR_R) * PAIR_F;
                const fx = (dx / d) * push, fy = (dy / d) * push;
                a.vx -= fx; a.vy -= fy; b.vx += fx; b.vy += fy;
              }
            }
          }
          for (const a of atoms) {
            a.vx *= damp; a.vy *= damp;
            a.vx = Math.max(-MAXV, Math.min(MAXV, a.vx));
            a.vy = Math.max(-MAXV, Math.min(MAXV, a.vy));
            a.x += a.vx; a.y += a.vy;
            if (a.x < LO) { a.x = LO; a.vx = Math.abs(a.vx) * 0.5; }
            else if (a.x > HI) { a.x = HI; a.vx = -Math.abs(a.vx) * 0.5; }
            if (a.y < LO) { a.y = LO; a.vy = Math.abs(a.vy) * 0.5; }
            else if (a.y > HI) { a.y = HI; a.vy = -Math.abs(a.vy) * 0.5; }
            a.el.setAttribute("cx", a.x.toFixed(2));
            a.el.setAttribute("cy", a.y.toFixed(2));
            ke += a.vx * a.vx + a.vy * a.vy;
            msd += (a.x - a.hx) ** 2 + (a.y - a.hy) ** 2;
          }

          if (phaseEl && (frame++ & 7) === 0) {
            const n = atoms.length;
            const lindemann = Math.sqrt(msd / n) / A_NN;
            const molten = lindemann > MELT;
            phaseEl.textContent = molten ? "Molten" : "Crystalline";
            phaseEl.dataset.phase = molten ? "molten" : "crystalline";
            if (tempEl) {
              const fill = Math.min(100, (Math.sqrt(ke / n) / 11) * 100);
              tempEl.style.width = Math.max(6, fill).toFixed(0) + "%";
            }
          }
          raf = requestAnimationFrame(tick);
        };

        const start = () => { if (!running) { running = true; raf = requestAnimationFrame(tick); } };
        const stop = () => { running = false; cancelAnimationFrame(raf); };
        new IntersectionObserver((es) => {
          for (const e of es) { inView = e.isIntersecting; inView ? start() : stop(); }
        }, { threshold: 0 }).observe(visual);
        document.addEventListener("visibilitychange", () => {
          if (document.hidden) stop(); else if (inView) start();
        });
      }
    </script>
  </body>
</html>

