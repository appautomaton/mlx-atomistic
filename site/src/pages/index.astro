---
// mlx-atomistic — landing page. Apple-Native (HIG) identity, light-first.
// System font stack renders real SF Pro / SF Mono on Apple devices.

// Inline monoline icon set — Apple-style 1.8px strokes, currentColor.
function icon(name) {
  const s = (p) =>
    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
  switch (name) {
    case "chip":
      return s(`<rect x="6" y="6" width="12" height="12" rx="2.5"/><rect x="9.5" y="9.5" width="5" height="5" rx="1"/><path d="M9 6V3M15 6V3M9 21v-3M15 21v-3M6 9H3M6 15H3M21 9h-3M21 15h-3"/>`);
    case "wave":
      return s(`<path d="M3 12c2.2 0 2.2-7 4.4-7S9.6 19 11.8 19 14 5 16.2 5 18.4 12 21 12"/>`);
    case "bond":
      return s(`<circle cx="6" cy="6" r="2.6"/><circle cx="18" cy="18" r="2.6"/><circle cx="18" cy="6" r="2"/><path d="M8 8l8 8M8.3 6H16M6 8.3V16"/>`);
    case "lattice":
      return s(`<circle cx="5" cy="5" r="1.4"/><circle cx="12" cy="5" r="1.4"/><circle cx="19" cy="5" r="1.4"/><circle cx="5" cy="12" r="1.4"/><circle cx="12" cy="12" r="1.4"/><circle cx="19" cy="12" r="1.4"/><circle cx="5" cy="19" r="1.4"/><circle cx="12" cy="19" r="1.4"/><circle cx="19" cy="19" r="1.4"/>`);
    case "terminal":
      return s(`<rect x="3" y="4" width="18" height="16" rx="2.5"/><path d="M7 9l3 3-3 3M13 15h4"/>`);
    case "check":
      return s(`<path d="M20 7L10 17l-5-5"/>`);
    default:
      return s(`<circle cx="12" cy="12" r="8"/>`);
  }
}

const features = [
  {
    title: "Apple Silicon native",
    desc: "MLX arrays and Metal kernels drive the GPU on your machine. No CUDA, no server, no cloud.",
    span: "wide",
    icon: "chip",
  },
  {
    title: "Plane-wave DFT",
    desc: "Kohn–Sham SCF, LDA + PBE via autodiff, Γ-point and k-mesh, Davidson diagonalization.",
    span: "tall",
    icon: "wave",
  },
  {
    title: "Molecular mechanics",
    desc: "Lennard-Jones, Coulomb, harmonic bonds and angles, periodic + RB torsions, bounded PME, Langevin NVT.",
    span: "std",
    icon: "bond",
  },
  {
    title: "Pseudopotentials",
    desc: "GTH and UPF readers, local + nonlocal projectors, analytic and finite-difference forces.",
    span: "std",
    icon: "lattice",
  },
  {
    title: "Python 3.13 · uv",
    desc: "Reproducible environments, fast sync, Jupyter-first exploration.",
    span: "std",
    icon: "terminal",
  },
  {
    title: "Reference-validated",
    desc: "OpenMM and LAMMPS reference surfaces keep the MLX runtime honest, run after run.",
    span: "wide",
    icon: "check",
  },
];

const stats = [
  { value: "LDA · PBE", label: "XC functionals" },
  { value: "NVE · NVT", label: "Integrators" },
  { value: "PME", label: "Long-range electrostatics" },
  { value: "Jupyter", label: "First-class visualization" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>mlx-atomistic — Apple Silicon atomistic simulation</title>
    <meta
      name="description"
      content="Apple Silicon-native atomistic simulation: an MLX + Metal DFT and MD runtime that runs the GPU on your Mac."
    />
    <meta name="theme-color" content="#fbfbfd" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content="mlx-atomistic" />
    <meta
      property="og:description"
      content="Apple Silicon-native atomistic simulation: MLX + Metal DFT and MD runtime."
    />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/mlx-atomistic/favicon.svg" />
    <script is:inline>
      // Light-first: honor an explicit choice, else follow the OS, defaulting to light.
      const stored = localStorage.getItem("starlight-theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const theme = stored ?? (prefersDark ? "dark" : "light");
      document.documentElement.dataset.theme = theme;
    </script>
  </head>
  <body>
    <nav class="nav" aria-label="Primary">
      <a class="nav__brand" href="/mlx-atomistic/">
        <svg width="25" height="25" viewBox="0 0 64 64" fill="none" aria-hidden="true">
          <g stroke="currentColor" stroke-width="2.4" opacity="0.3">
            <line x1="32" y1="32" x2="47" y2="32" /><line x1="32" y1="32" x2="39.5" y2="19" /><line x1="32" y1="32" x2="24.5" y2="19" />
            <line x1="32" y1="32" x2="17" y2="32" /><line x1="32" y1="32" x2="24.5" y2="45" /><line x1="32" y1="32" x2="39.5" y2="45" />
          </g>
          <g fill="currentColor">
            <circle cx="47" cy="32" r="4" opacity="0.7" /><circle cx="39.5" cy="19" r="4" opacity="0.7" /><circle cx="24.5" cy="19" r="4" opacity="0.7" />
            <circle cx="17" cy="32" r="4" opacity="0.7" /><circle cx="24.5" cy="45" r="4" opacity="0.7" /><circle cx="39.5" cy="45" r="4" opacity="0.7" />
            <circle cx="32" cy="32" r="5.5" />
          </g>
        </svg>
        <span>mlx-atomistic</span>
      </a>
      <div class="nav__links">
        <a href="/mlx-atomistic/overview/">Overview</a>
        <a href="/mlx-atomistic/dft/dft-scf-core/">DFT</a>
        <a href="/mlx-atomistic/mm/molecular-mechanics/">MD</a>
        <a href="/mlx-atomistic/benchmarks/">Benchmarks</a>
      </div>
      <div class="nav__actions">
        <button id="theme-toggle" class="icon-btn" aria-label="Toggle color theme">
          <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
        <a class="icon-btn" href="https://github.com/appautomaton/mlx-atomistic" aria-label="GitHub repository">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.9 10.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"/></svg>
        </a>
      </div>
    </nav>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero__inner">
          <span class="eyebrow">Apple Silicon · MLX · Metal</span>
          <h1>
            Atomistic simulation,<br />
            <span class="accent">native to your Mac.</span>
          </h1>
          <p class="lead">
            An MD and DFT runtime built directly on MLX and Metal — it runs the
            GPU on your machine, not a wrapper around someone else's cluster.
          </p>
          <div class="cta-row">
            <a class="btn btn--primary" href="/mlx-atomistic/overview/">Get started</a>
            <a class="btn btn--link" href="https://github.com/appautomaton/mlx-atomistic">
              View on GitHub
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>

        <!-- Hero visual: an orbital atom seated inside a silicon die. -->
        <div class="hero__visual" aria-hidden="true">
          <div class="hero__aurora"></div>
          <svg class="lattice" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="die" x1="40" y1="40" x2="280" y2="280" gradientUnits="userSpaceOnUse">
                <stop class="die-a" />
                <stop offset="1" class="die-b" />
              </linearGradient>
              <radialGradient id="atom" cx="0.35" cy="0.3" r="0.8">
                <stop class="atom-a" />
                <stop offset="1" class="atom-b" />
              </radialGradient>
              <radialGradient id="atomA" cx="0.35" cy="0.3" r="0.85">
                <stop class="atomA-a" />
                <stop offset="1" class="atomA-b" />
              </radialGradient>
            </defs>
            <!-- package pins -->
            <g class="pins">
              <line x1="100" y1="40" x2="100" y2="14" /><line x1="160" y1="40" x2="160" y2="14" /><line x1="220" y1="40" x2="220" y2="14" />
              <line x1="100" y1="280" x2="100" y2="306" /><line x1="160" y1="280" x2="160" y2="306" /><line x1="220" y1="280" x2="220" y2="306" />
              <line x1="40" y1="100" x2="14" y2="100" /><line x1="40" y1="160" x2="14" y2="160" /><line x1="40" y1="220" x2="14" y2="220" />
              <line x1="280" y1="100" x2="306" y2="100" /><line x1="280" y1="160" x2="306" y2="160" /><line x1="280" y1="220" x2="306" y2="220" />
            </g>
            <!-- silicon die -->
            <rect x="40" y="40" width="240" height="240" rx="40" fill="url(#die)" />
            <rect x="40" y="40" width="240" height="240" rx="40" class="die-edge" />
            <rect x="74" y="74" width="172" height="172" rx="26" class="die-inner" />
            <!-- close-packed atomic lattice (19-atom hex cluster) -->
            <g class="atoms">
              <!-- outer shell -->
              <circle cx="228" cy="160" r="8" fill="url(#atom)" class="j" style="--d:0s" />
              <circle cx="194" cy="101" r="8" fill="url(#atom)" />
              <circle cx="126" cy="101" r="8" fill="url(#atom)" class="j" style="--d:0.7s" />
              <circle cx="92" cy="160" r="8" fill="url(#atom)" />
              <circle cx="126" cy="219" r="8" fill="url(#atom)" />
              <circle cx="194" cy="219" r="8" fill="url(#atom)" class="j" style="--d:1.3s" />
              <circle cx="211" cy="131" r="8" fill="url(#atom)" />
              <circle cx="160" cy="101" r="8" fill="url(#atom)" />
              <circle cx="109" cy="131" r="8" fill="url(#atom)" />
              <circle cx="109" cy="189" r="8" fill="url(#atomA)" />
              <circle cx="160" cy="219" r="8" fill="url(#atom)" class="j" style="--d:2s" />
              <circle cx="211" cy="189" r="8" fill="url(#atom)" />
              <!-- first shell -->
              <circle cx="194" cy="160" r="9" fill="url(#atom)" />
              <circle cx="177" cy="131" r="9" fill="url(#atomA)" />
              <circle cx="143" cy="131" r="9" fill="url(#atom)" />
              <circle cx="126" cy="160" r="9" fill="url(#atom)" />
              <circle cx="143" cy="189" r="9" fill="url(#atom)" />
              <circle cx="177" cy="189" r="9" fill="url(#atomA)" />
              <!-- center -->
              <circle cx="160" cy="160" r="10.5" fill="url(#atomA)" class="j" style="--d:0.4s" />
            </g>
          </svg>
        </div>
      </section>

      <!-- Bento -->
      <section class="section">
        <p class="kicker">Capabilities</p>
        <h2 class="section-title">One runtime, two scales.</h2>
        <div class="bento">
          {
            features.map((f) => (
              <article class={`card card--${f.span}`}>
                <span class="card__icon" set:html={icon(f.icon)} />
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Stats -->
      <section class="stats">
        {
          stats.map((s) => (
            <div class="stat">
              <div class="stat__value">{s.value}</div>
              <div class="stat__label">{s.label}</div>
            </div>
          ))
        }
      </section>

      <!-- Quick start -->
      <section class="section section--narrow">
        <p class="kicker">Quick start</p>
        <h2 class="section-title">Up and running in three lines.</h2>
        <div class="window">
          <div class="window__bar">
            <span class="traffic"><i class="t-red" /><i class="t-amber" /><i class="t-green" /></span>
            <span class="window__title">zsh — mlx-atomistic</span>
          </div>
          <pre><code><span class="c-prompt">$</span> uv venv --python 3.13
<span class="c-prompt">$</span> uv sync --extra notebook --group dev
<span class="c-prompt">$</span> uv run jupyter lab

<span class="c-comment"># run a DFT SCF benchmark</span>
<span class="c-prompt">$</span> uv run python -m mlx_atomistic.benchmarks.dft_scf \
    --sizes 8,16,24,32 --iterations 5 --mixer both --json</code></pre>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <span>mlx-atomistic · Apple Silicon atomistic simulation</span>
        <div class="footer__links">
          <a href="/mlx-atomistic/overview/">Docs</a>
          <a href="https://github.com/appautomaton/mlx-atomistic">GitHub</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById("theme-toggle");
      toggle?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme || "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("starlight-theme", next);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Apple system palette — light (default). */
    --bg: #fbfbfd;
    --bg-section: #f5f5f7;
    --surface: #ffffff;
    --ink: #1d1d1f;
    --ink-2: #6e6e73;
    --ink-3: #86868b;
    --blue: #6c5ce7;
    --blue-hover: #5a4bd4;
    --on-accent: #ffffff;
    --border: #d2d2d7;
    --border-soft: rgba(0, 0, 0, 0.08);
    --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.06);
    --shadow-float: 0 20px 60px rgba(0, 0, 0, 0.12);
    --glass: rgba(251, 251, 253, 0.72);

    --font-sans: -apple-system, BlinkMacSystemFont, "SF Pro Display",
      "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
    --font-mono: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Monaco,
      Consolas, monospace;

    --maxw: 1080px;
  }

  [data-theme="dark"] {
    --bg: #000000;
    --bg-section: #0a0a0b;
    --surface: #161617;
    --ink: #f5f5f7;
    --ink-2: #a1a1a6;
    --ink-3: #86868b;
    --blue: #b7abff;
    --blue-hover: #c9c0ff;
    --on-accent: #14122b;
    --border: #2a2a2c;
    --border-soft: rgba(255, 255, 255, 0.1);
    --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.4);
    --shadow-float: 0 24px 70px rgba(0, 0, 0, 0.6);
    --glass: rgba(10, 10, 11, 0.7);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--ink);
    line-height: 1.5;
    letter-spacing: -0.01em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* ---------- Floating nav ---------- */
  .nav {
    position: fixed;
    top: 0.85rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: min(var(--maxw), calc(100% - 2rem));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 0.7rem 0.55rem 1.1rem;
    background: var(--glass);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border: 1px solid var(--border-soft);
    border-radius: 18px;
    box-shadow: var(--shadow-card);
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
  }
  .nav__brand svg { color: var(--blue); }

  .nav__links {
    display: flex;
    gap: 1.6rem;
    font-size: 0.875rem;
    color: var(--ink-2);
  }
  .nav__links a {
    transition: color 0.15s ease;
  }
  .nav__links a:hover { color: var(--ink); }

  .nav__actions {
    display: flex;
    gap: 0.25rem;
  }
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: none;
    color: var(--ink-2);
    background: transparent;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .icon-btn:hover {
    color: var(--ink);
    background: var(--border-soft);
  }
  .icon-sun { display: none; }
  [data-theme="dark"] .icon-sun { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }

  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 9.5rem 1.5rem 2rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--blue);
    margin-bottom: 1.1rem;
  }

  .hero h1 {
    font-size: clamp(2.6rem, 6.5vw, 4.75rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.035em;
    margin-bottom: 1.4rem;
  }
  .accent { color: var(--blue); }

  .lead {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink-2);
    max-width: 660px;
    margin: 0 auto 2rem;
    letter-spacing: -0.015em;
  }

  .cta-row {
    display: flex;
    gap: 1.4rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    transition: all 0.18s ease;
  }
  .btn--primary {
    padding: 0.7rem 1.5rem;
    background: var(--blue);
    color: var(--on-accent);
    border-radius: 980px;
  }
  .btn--primary:hover {
    background: var(--blue-hover);
    transform: scale(1.02);
  }
  .btn--link {
    color: var(--blue);
  }
  .btn--link svg { transition: transform 0.18s ease; }
  .btn--link:hover svg { transform: translateX(3px); }

  /* ---------- Hero visual ---------- */
  .hero__visual {
    position: relative;
    margin: 3.5rem auto 0;
    width: min(440px, 80vw);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
  }
  /* Iridescent spectral glow leaking from under the silicon die.
     Pure CSS: one blurred conic gradient, slow rotation + hue drift.
     It is the only glow layer now — no blue wash fighting the color. */
  .hero__aurora {
    position: absolute;
    left: 50%;
    top: 54%;
    width: 92%;
    height: 80%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      #ff6f91,
      #ff9f45,
      #ffd23f,
      #4ad991,
      #2fb8f5,
      #6c7bff,
      #c265ff,
      #ff6f91
    );
    filter: blur(40px) saturate(165%);
    opacity: 0.72;
    will-change: transform, filter;
    animation: aurora-spin 18s linear infinite,
      aurora-breathe 9s ease-in-out infinite;
  }
  [data-theme="dark"] .hero__aurora {
    opacity: 0.78;
    filter: blur(46px) saturate(175%);
  }
  @keyframes aurora-spin {
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }
  @keyframes aurora-breathe {
    0%, 100% {
      filter: blur(40px) saturate(160%) hue-rotate(0deg);
      opacity: 0.66;
    }
    50% {
      filter: blur(46px) saturate(180%) hue-rotate(45deg);
      opacity: 0.82;
    }
  }
  .lattice {
    position: relative;
    width: 100%;
    height: 100%;
    /* Light, slightly cool shadow so the aurora's color reads through it. */
    filter: drop-shadow(0 14px 28px rgba(40, 52, 92, 0.1));
    animation: float 7s ease-in-out infinite;
  }
  [data-theme="dark"] .lattice {
    filter: drop-shadow(0 22px 52px rgba(0, 0, 0, 0.5));
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .lattice .die-a { stop-color: #f5f7fb; }
  .lattice .die-b { stop-color: #d9e2f2; }
  [data-theme="dark"] .lattice .die-a { stop-color: #26262a; }
