    <script is:inline>
      const toggle = document.getElementById("theme-toggle");
      toggle?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme || "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("starlight-theme", next);
      });

      // Condense the floating nav once the page scrolls past the top. A 1px
      // sentinel is cheaper and smoother than a scroll handler: the observer
      // fires only as it crosses the viewport edge.
      const nav = document.querySelector(".nav");
      const sentinel = document.getElementById("nav-sentinel");
      if (nav && sentinel && "IntersectionObserver" in window) {
        new IntersectionObserver(
          ([entry]) => nav.classList.toggle("is-scrolled", !entry.isIntersecting),
        ).observe(sentinel);
      }

      // Mobile menu: the hamburger toggles a dropdown of the nav links.
      // Closes on link tap, Escape, or a click outside the nav.
      const menuBtn = document.getElementById("nav-menu-btn");
      const setMenu = (open) => {
        nav?.setAttribute("data-menu", open ? "open" : "closed");
        menuBtn?.setAttribute("aria-expanded", String(open));
        menuBtn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      };
      menuBtn?.addEventListener("click", () =>
        setMenu(nav?.getAttribute("data-menu") !== "open"),
      );
      nav?.querySelectorAll(".nav__links a").forEach((a) =>
        a.addEventListener("click", () => setMenu(false)),
      );
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setMenu(false);
      });
      document.addEventListener("click", (e) => {
        if (nav?.getAttribute("data-menu") === "open" && !nav.contains(e.target))
          setMenu(false);
      });
    </script>

    <!-- Interactive molecular-dynamics toy on the hero lattice.
         A bonded crystal, not free spheres: harmonic bonds between first-shell
         neighbours carry phonons, a weak Einstein tether anchors the
         art-directed lattice, soft pair repulsion is the excluded volume, and
         Langevin damping + noise set the temperature. Dragging stirs momentum
         in and heats the cell; over-strained bonds break (melting) and re-form
         as the lattice anneals home. The chip reads a smoothed Lindemann
         ratio; halos glow with per-atom kinetic energy. The idle lattice
         stays alive on real solid-state physics: an occasional plane-wave
         phonon pulse rolls through it, the vacancy migrates site-to-site
         (an atom glides into the hole and the network re-knits), and the
         teal exciton lobe wanders atom-to-atom. -->
    <script>
      const visual = document.querySelector(".hero__visual");
      const svg = visual?.querySelector("svg.lattice");
      const group = svg?.querySelector(".atoms");
      const hero = visual?.closest(".hero");
      const phaseEl = hero?.querySelector("[data-phase]");
      const tempEl = hero?.querySelector("[data-temp]");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (visual && svg && group && !reduce) {
        hero?.querySelector(".hero__readout")?.removeAttribute("hidden");
        hero?.querySelector(".hero__hint")?.removeAttribute("hidden");

        // Site/occupancy model: atoms occupy lattice sites; every edge of the
        // site graph has a line that shows only while both ends are occupied.
        // This is what lets the vacancy migrate with the network re-knitting
        // itself around it.
        const halos = [...svg.querySelectorAll(".halos circle")];
        const excs = [...svg.querySelectorAll(".excs circle")];
        const bondsG = svg.querySelector(".bonds");
        const sites0 = JSON.parse(bondsG.getAttribute("data-sites"));
        const sites = sites0.map((s) => [...s]);
        const occ = new Array(sites.length).fill(-1);
        const atoms = [...group.querySelectorAll("circle")].map((el, i) => {
          const site = +el.getAttribute("data-s");
          const [hx, hy] = sites[site];
          occ[site] = i;
          return { el, halo: halos[i], exc: excs[i], site, hx, hy, x: hx, y: hy, vx: 0, vy: 0, hop: 0 };
        });
        let vac = occ.indexOf(-1);
        const excited = new Set(atoms.map((a, i) => (a.exc.style.opacity === "1" ? i : -1)).filter((i) => i >= 0));
        const edges = [...bondsG.querySelectorAll("line")].map((el) => {
          const [i, j] = el.getAttribute("data-e").split(" ").map(Number);
          return { el, i, j, rest: Math.hypot(sites[j][0] - sites[i][0], sites[j][1] - sites[i][1]), broken: false, op: 0.45 };
        });
        const nbrs = sites.map(() => []);
        for (const e of edges) { nbrs[e.i].push(e.j); nbrs[e.j].push(e.i); }

        const TETHER = 0.02;    // weak Einstein anchor to each home site
        const KBOND = 0.05;     // harmonic bond stiffness (carries phonons)
        const BREAK = 1.42;     // a bond breaks past this stretch ratio
        const REFORM = 1.12;    // ...and re-forms once back within this
        const BOND_OP = 0.45;   // resting bond opacity (fades with strain)
        const DAMP = 0.9;       // cooling per frame (anneal / recrystallize)
        const DAMP_HOT = 0.985; // barely cools while you stir
        const MOUSE_R = 72;     // cursor influence radius (viewBox units)
        const MOUSE_F = 1.3;    // hover push strength
        const STIR = 0.16;      // fraction of drag momentum handed to atoms
        const PAIR_R = 24;      // soft repulsion cutoff (excluded volume)
        const PAIR_F = 0.45;
        const NOISE = 0.05;     // idle thermal vibration
        const MAXV = 14;        // velocity clamp (stability)
        const LO = 86, HI = 234; // simulation-cell walls
        const A_NN = 34;        // nearest-neighbour spacing
        const MELT = 0.16;      // Lindemann ratio at melting
        const ANNEAL = 0.11;    // ...and where "annealing" begins
        const PULSE_EVERY = 9000; // idle ms between phonon pulses
        const PULSE_V = 0.19;   // wavefront speed, viewBox units per ms

        const HOP_EVERY = 6500;  // idle ms between vacancy hops
        const EXC_EVERY = 4200;  // ms between exciton transfers
        const SPIN = (2 * Math.PI) / (120 * 60); // grain rotation: one rev ~2min

        const mouse = { x: -999, y: -999, dx: 0, dy: 0, on: false, down: false };
        let heat = 0, frame = 0, lEma = 0, phi = 0;
        let lastPulse = performance.now() - PULSE_EVERY + 2500; // first pulse ~2.5s in
        let lastHop = performance.now() - HOP_EVERY + 3400;     // first hop ~3.4s in
        let lastExc = performance.now() - EXC_EVERY + 5300;     // first transfer ~5.3s in
        const pulse = { t0: -1, cos: 1, sin: 0, min: 0 };

        const toSvg = (cx, cy) => {
          const r = svg.getBoundingClientRect();
          return { x: ((cx - r.left) / r.width) * 320, y: ((cy - r.top) / r.height) * 320 };
        };
        visual.addEventListener("pointermove", (e) => {
          const p = toSvg(e.clientX, e.clientY);
          if (mouse.down && mouse.on) {
            mouse.dx += p.x - mouse.x;
            mouse.dy += p.y - mouse.y;
            heat = Math.min(heat + 0.5, 6);
          }
          mouse.x = p.x; mouse.y = p.y; mouse.on = true;
        });
        visual.addEventListener("pointerdown", () => { mouse.down = true; });
        window.addEventListener("pointerup", () => { mouse.down = false; });
        visual.addEventListener("pointerleave", () => { mouse.on = false; });

        let raf = 0, running = false, inView = false, lastT = 0;
        const tick = () => {
          // dt in 60fps-frame units: forces, damping and noise all scale with
          // real elapsed time, so the toy behaves the same on a 60Hz panel,
          // a 120Hz ProMotion display, or a throttled tab.
          const now = performance.now();
          const dtn = lastT ? Math.min((now - lastT) / 16.7, 2.5) : 1;
          lastT = now;
          heat *= Math.pow(0.97, dtn); // slow decay: the anneal is watchable
          const damp = Math.pow(mouse.down ? DAMP_HOT : DAMP, dtn);
          const hot = Math.min(heat / 6, 1);
          // Hot lattice goes floppy; a cool one anchors firmly, so recovery
          // can push through the excluded-volume barrier of swapped atoms.
          const springK = TETHER * (1.8 - 1.65 * hot) * dtn;
          const kBond = KBOND * (1 - Math.min(hot, 0.85)) * dtn;
          const noiseAmp = (NOISE + heat) * Math.sqrt(dtn);
          const sx = Math.max(-24, Math.min(24, mouse.dx)) * STIR;
          const sy = Math.max(-24, Math.min(24, mouse.dy)) * STIR;
          let ke = 0, msd = 0, brokenN = 0;

          // Grain rotation: the crystal's ground state revolves imperceptibly
          // slowly about the die centre and the atoms tether-follow, so the
          // asymmetric silhouette presents every orientation over time. Real
          // crystallites reorient like this while annealing. Rotation
          // preserves distances, so bond rest lengths are untouched.
          phi += SPIN * dtn;
          const cph = Math.cos(phi), sph = Math.sin(phi);
          for (let k = 0; k < sites.length; k++) {
            const dx = sites0[k][0] - 160, dy = sites0[k][1] - 160;
            sites[k][0] = 160 + dx * cph - dy * sph;
            sites[k][1] = 160 + dx * sph + dy * cph;
          }
          for (const a of atoms) { a.hx = sites[a.site][0]; a.hy = sites[a.site][1]; }

          // Idle phonon pulse: a plane wavefront sweeps the lattice, giving
          // each atom a small coherent kick as it passes. Wall-clock timed so
          // the cadence is the same at any display refresh rate.
          if (pulse.t0 >= 0) {
            const front = pulse.min + (now - pulse.t0) * PULSE_V;
            for (const a of atoms) {
              const p = a.hx * pulse.cos + a.hy * pulse.sin;
              if (Math.abs(p - front) < 16) {
                a.vx += pulse.cos * 0.35 * dtn;
                a.vy += pulse.sin * 0.35 * dtn;
              }
            }
            if (now - pulse.t0 > 1300) pulse.t0 = -1;
          } else if (!mouse.down && heat < 0.05 && now - lastPulse > PULSE_EVERY) {
            lastPulse = now;
            const th = Math.random() * Math.PI * 2;
            pulse.cos = Math.cos(th); pulse.sin = Math.sin(th);
            let m = 1e9;
            for (const a of atoms) m = Math.min(m, a.hx * pulse.cos + a.hy * pulse.sin);
            pulse.min = m; pulse.t0 = now;
          }

          // Self-anneal: a cool lattice frozen away from its ground state
          // (a quenched defect after a hard stir) gets a gentle home-directed
          // nudge, so the crystallite always finds its way back.
          if ((frame & 63) === 0 && heat < 0.3 && lEma > 0.06) {
            for (const a of atoms) {
              const dx = a.hx - a.x, dy = a.hy - a.y;
              if (dx * dx + dy * dy > 36) { a.vx += dx * 0.05; a.vy += dy * 0.05; }
            }
          }

          // Vacancy migration: every few idle seconds a neighbouring atom is
          // retargeted into the hole and glides over (canonical solid-state
          // diffusion), so the crystallite reshapes with nobody touching it.
          if (!mouse.down && heat < 0.2 && now - lastHop > HOP_EVERY) {
            lastHop = now;
            const cands = nbrs[vac].filter((s) => occ[s] >= 0);
            if (cands.length) {
              const s = cands[(Math.random() * cands.length) | 0];
              const a = atoms[occ[s]];
              occ[vac] = occ[s]; occ[s] = -1;
              a.site = vac; // home re-derives from the site next frame
              vac = s;
            }
          }
          // Exciton transfer: the teal excitation wanders atom-to-atom (the
          // .exc overlays crossfade via CSS), so the lobe drifts and reshapes.
          if (now - lastExc > EXC_EVERY && excited.size) {
            lastExc = now;
            const from = [...excited][(Math.random() * excited.size) | 0];
            const targets = nbrs[atoms[from].site].filter((s) => occ[s] >= 0 && !excited.has(occ[s]));
            if (targets.length) {
              const to = occ[targets[(Math.random() * targets.length) | 0]];
              excited.delete(from); excited.add(to);
              atoms[from].exc.style.opacity = "0";
              atoms[to].exc.style.opacity = "1";
            }
          }

          for (const a of atoms) {
            a.vx += (a.hx - a.x) * springK;
            a.vy += (a.hy - a.y) * springK;
            if (mouse.on) {
              const dx = a.x - mouse.x, dy = a.y - mouse.y;
              const d = Math.hypot(dx, dy);
              if (d < MOUSE_R && d > 0.001) {
                const w = 1 - d / MOUSE_R;
                const push = w * MOUSE_F * dtn;
                a.vx += (dx / d) * push;
                a.vy += (dy / d) * push;
                if (mouse.down) { a.vx += sx * w; a.vy += sy * w; } // stirring
              }
            }
            a.vx += (Math.random() - 0.5) * noiseAmp;
            a.vy += (Math.random() - 0.5) * noiseAmp;
          }
          mouse.dx = 0; mouse.dy = 0;

          // Harmonic bonds: the lattice's real cohesion. Stretched bonds pull,
          // compressed bonds push, over-strained bonds let go until the pair
          // finds its rest distance again. An edge with a vacant end is
          // dormant — it wakes when the vacancy moves on.
          for (const bd of edges) {
            if (occ[bd.i] < 0 || occ[bd.j] < 0) { bd.op = 0; continue; }
            const A = atoms[occ[bd.i]], B = atoms[occ[bd.j]];
            const dx = B.x - A.x, dy = B.y - A.y;
            const d = Math.hypot(dx, dy) || 0.001;
            if (bd.broken) {
              if (d < bd.rest * REFORM) bd.broken = false;
            } else if (d > bd.rest * BREAK) {
              bd.broken = true;
            }
            if (bd.broken) {
              brokenN++;
              bd.op = 0;
            } else {
              const f = (kBond * (d - bd.rest)) / d;
              A.vx += f * dx; A.vy += f * dy;
              B.vx -= f * dx; B.vy -= f * dy;
              const strain = Math.abs(d - bd.rest) / bd.rest;
              bd.op = Math.max(0, BOND_OP * (1 - strain * 2.2));
            }
          }
          for (let i = 0; i < atoms.length; i++) {
            for (let j = i + 1; j < atoms.length; j++) {
              const a = atoms[i], b = atoms[j];
              const dx = b.x - a.x, dy = b.y - a.y;
              const d = Math.hypot(dx, dy);
              if (d < PAIR_R && d > 0.001) {
                const push = (1 - d / PAIR_R) * PAIR_F * dtn;
                const fx = (dx / d) * push, fy = (dy / d) * push;
                a.vx -= fx; a.vy -= fy; b.vx += fx; b.vy += fy;
              }
            }
          }

          for (const a of atoms) {
            a.vx *= damp; a.vy *= damp;
            a.vx = Math.max(-MAXV, Math.min(MAXV, a.vx));
            a.vy = Math.max(-MAXV, Math.min(MAXV, a.vy));
            a.x += a.vx * dtn; a.y += a.vy * dtn;
            if (a.x < LO) { a.x = LO; a.vx = Math.abs(a.vx) * 0.5; }
            else if (a.x > HI) { a.x = HI; a.vx = -Math.abs(a.vx) * 0.5; }
            if (a.y < LO) { a.y = LO; a.vy = Math.abs(a.vy) * 0.5; }
            else if (a.y > HI) { a.y = HI; a.vy = -Math.abs(a.vy) * 0.5; }
            a.el.setAttribute("cx", a.x.toFixed(2));
            a.el.setAttribute("cy", a.y.toFixed(2));
            a.exc.setAttribute("cx", a.x.toFixed(2));
            a.exc.setAttribute("cy", a.y.toFixed(2));
            // Thermal halo: glow tracks kinetic energy, so heat is visible
            // where it lives. Skipped while imperceptible to save attr churn.
            const op = Math.min(0.6, (a.vx * a.vx + a.vy * a.vy) * 0.02);
            if (op > 0.02 || a.hop > 0.02) {
              a.halo.setAttribute("cx", a.x.toFixed(2));
              a.halo.setAttribute("cy", a.y.toFixed(2));
              a.halo.setAttribute("opacity", op.toFixed(2));
            }
            a.hop = op;
            ke += a.vx * a.vx + a.vy * a.vy;
            msd += (a.x - a.hx) ** 2 + (a.y - a.hy) ** 2;
          }
          for (const bd of edges) {
            if (occ[bd.i] < 0 || occ[bd.j] < 0) { bd.el.style.strokeOpacity = "0"; continue; }
            const A = atoms[occ[bd.i]], B = atoms[occ[bd.j]];
            bd.el.setAttribute("x1", A.x.toFixed(1));
            bd.el.setAttribute("y1", A.y.toFixed(1));
            bd.el.setAttribute("x2", B.x.toFixed(1));
            bd.el.setAttribute("y2", B.y.toFixed(1));
            bd.el.style.strokeOpacity = bd.op.toFixed(2);
          }

          if (phaseEl && (frame++ & 7) === 0) {
            const n = atoms.length;
            // Smoothed Lindemann ratio, so the chip narrates the transition
            // instead of flickering across it.
            lEma += 0.3 * (Math.sqrt(msd / n) / A_NN - lEma);
            const phase =
              lEma > MELT ? "molten"
              : lEma > ANNEAL || brokenN > 2 ? "annealing"
              : "crystalline";
            if (phase !== phaseEl.dataset.phase) {
              phaseEl.dataset.phase = phase;
              phaseEl.textContent =
                phase === "molten" ? "Molten"
                : phase === "annealing" ? "Annealing"
                : "Crystalline";
            }
            if (tempEl) {
              const fill = Math.min(100, (Math.sqrt(ke / n) / 11) * 100);
              tempEl.style.width = Math.max(6, fill).toFixed(0) + "%";
            }
          }
          raf = requestAnimationFrame(tick);
        };

        const start = () => { if (!running) { running = true; lastT = 0; raf = requestAnimationFrame(tick); } };
        const stop = () => { running = false; cancelAnimationFrame(raf); };
        new IntersectionObserver((es) => {
          for (const e of es) { inView = e.isIntersecting; inView ? start() : stop(); }
        }, { threshold: 0 }).observe(visual);
        document.addEventListener("visibilitychange", () => {
          if (document.hidden) stop(); else if (inView) start();
        });
      }
    </script>
  </body>
</html>

